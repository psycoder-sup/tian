{
  "permissions": {
    "allow": [
      "Bash(xcodebuild test:*)",
      "Bash(xcodegen:*)",
      "Bash(xcrun swiftc -typecheck:*)",
      "Bash(zig build:*)",
      "Bash(xcodebuild build -scheme tian:*)",
      "Bash(xcodebuild -project tian.xcodeproj:*)",
      "Bash(xcodebuild -project */tian/tian.xcodeproj *)",
      "Bash(./scripts/build.sh *)",
      "Read(tian/Vendor/*)",
      "Bash(gh pr merge *)"
    ]
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "markdown-review@local": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/psycoder/.local/bin/graphify hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/psycoder/.local/bin/graphify hook-guard read"
          }
        ]
      }
    ]
  }
}