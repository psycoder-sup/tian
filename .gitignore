# Xcode
*.xcodeproj/
xcuserdata/
DerivedData/
*.xcworkspace/

# Build
build/
*.o
*.d

# macOS
.DS_Store

# Scratch dir for temporary code/experiments (used instead of /tmp)
.dev/tmp/

# Superpowers brainstorming mockups
.superpowers/

# Claude Code local state
.claude/scheduled_tasks.lock
.claude/agent-memory/
.claude/worktrees/

# tian-cli config artifacts
.tian/*.rejected

# Local code-signing config for scripts/release.sh (see .tian/signing.env.example)
.tian/signing.env

# Swift Package Manager
.build/
Package.resolved

# Ghostty build artifacts (run scripts/build-ghostty.sh to generate)
.ghostty-src
tian/Vendor
tian/Vendor/ghostty/lib/
tian/Vendor/GhosttyKit.xcframework/
tian/Vendor/ghostty.h
tian/Vendor/resources/

# graphify per-run dated snapshots (regenerated on every rebuild — churn only)
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# graphify AST cache (regenerated by `graphify update`; versioned dir churns every rebuild)
graphify-out/cache/

# graphify derived artifacts + run metadata (regenerated each rebuild — churn only;
# graph.json / GRAPH_REPORT.md / manifest.json / wiki stay tracked, per CLAUDE.md)
graphify-out/graph.html
graphify-out/cost.json
graphify-out/.graphify_python
graphify-out/.graphify_root
