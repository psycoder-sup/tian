# Code-signing configuration for scripts/release.sh
#
# Copy this file to `.tian/signing.env` (gitignored) and fill in your values,
# or export these variables in your environment / CI.
#
# These identifiers are NOT secret — they appear in any shipped, signed binary —
# but they are kept out of version control so each maintainer/contributor signs
# releases with their own Apple Developer identity.

# Your 10-character Apple Developer Team ID (Apple Developer portal → Membership).
DEVELOPMENT_TEAM=XXXXXXXXXX

# The exact code-signing identity string, as shown by:
#   security find-identity -v -p codesigning
# Leave as "Developer ID Application" to auto-select when you have exactly one
# such certificate in your keychain.
SIGN_IDENTITY="Developer ID Application"
