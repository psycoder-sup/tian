{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "aterm-cli pane set-restore-command --command 'claude --resume $SESSION_ID'"
          },
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state active"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state busy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state idle"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state idle"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state needs_attention"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state inactive"
          }
        ]
      }
    ]
  }
}
