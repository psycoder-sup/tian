#!/bin/bash
# claude wrapper for tian — injects session restore hook when running inside tian.
# Bundled at Contents/Resources/claude; added to PATH via EnvironmentBuilder.

SELF_DIR="$(dirname "$0")"
REAL_CLAUDE=$(PATH="${PATH//$SELF_DIR:}" command -v claude)

if [ -z "$REAL_CLAUDE" ]; then
  echo "claude: command not found" >&2
  exit 127
fi

if [ -n "$TIAN_SOCKET" ]; then
  exec "$REAL_CLAUDE" --settings "$SELF_DIR/tian-claude-settings.json" "$@"
else
  exec "$REAL_CLAUDE" "$@"
fi
