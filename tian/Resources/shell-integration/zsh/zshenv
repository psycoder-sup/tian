# tian ZDOTDIR bootstrap for zsh. Restores the user's ZDOTDIR, sources
# their .zshenv, then loads tian and ghostty zsh integrations. Ghostty's
# integration emits OSC 133 prompt markers, which ghostty relies on to
# tell when the cursor is at a prompt — without them the close-pane
# dialog fires even for idle panes.

if [[ -n "${TIAN_ORIGINAL_ZDOTDIR+X}" ]]; then
    builtin export ZDOTDIR="$TIAN_ORIGINAL_ZDOTDIR"
    builtin unset TIAN_ORIGINAL_ZDOTDIR
else
    builtin unset ZDOTDIR
fi

{
    builtin typeset _tian_file="${ZDOTDIR-$HOME}/.zshenv"
    [[ ! -r "$_tian_file" ]] || builtin source -- "$_tian_file"
} always {
    builtin unset _tian_file

    if [[ -o interactive ]]; then
        if [[ -n "${TIAN_SHELL_INTEGRATION_DIR:-}" \
           && -r "${TIAN_SHELL_INTEGRATION_DIR}/tian-zsh-integration.zsh" ]]; then
            builtin source -- "${TIAN_SHELL_INTEGRATION_DIR}/tian-zsh-integration.zsh"
        fi

        if [[ -n "${GHOSTTY_RESOURCES_DIR:-}" ]]; then
            builtin typeset _tian_ghostty_file="${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration"
            if [[ -r "$_tian_ghostty_file" ]]; then
                builtin autoload -Uz -- "$_tian_ghostty_file"
                ghostty-integration
                builtin unfunction -- ghostty-integration
            fi
            builtin unset _tian_ghostty_file
        fi
    fi
}
